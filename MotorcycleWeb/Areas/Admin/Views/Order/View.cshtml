<!-- Main content -->
<section class="content">

    <!-- Default box -->
    <div class="card">
        <div class="card-header">
            <h3 class="card-title">Chi tiết đơn hàng</h3>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-6">
                    <div class="form-group">
                        <label>Mã đơn hàng</label>
                        <p class="form-control">@Model.Code</p>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group">
                        <label>Họ tên khách hàng</label>
                        <p class="form-control">@Model.CustomerName</p>
                    </div>
                </div>
            </div>
            <div class="row">
                <div class="col-md-6">
                    <div class="form-group">
                        <label>Tổng tiền</label>
                        <p class="form-control">@Model.TotalAmount.ToString("#,##0") VND</p>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group">
                        <label>Số điện thoại </label>
                        <p class="form-control">@Model.Phone</p>
                    </div>
                </div>
            </div>
            
            <div class="row">
                <div class="col-md-6">
                    <div class="form-group">
                        <label>Ngày tạo</label>
                        <p class="form-control">@Model.CreateDate.ToString("dd/MM/yyyy")</p>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group">
                        <label>Eamil</label>
                        <p class="form-control">@Model.Email</p>
                    </div>
                </div>
            </div>
            <div class="row">
                <div class="col-md-6">
                    <div class="form-group">
                        <label>Thanh toán</label>
                        <p class="form-control">@(Model.TypePayment == 1? "Chờ thanh toán":"Đã thanh toán")</p>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group">
                        <label>Trạng thái </label>
                        <p class="form-control">
                            @{
                                string statusText;
                                switch (Model.Status)
                                {
                                    case MotorcycleWeb.Models.EF.Enums.OrderStatus.Confirmed:
                                        statusText = "Chờ xác nhận";
                                        break;
                                    case MotorcycleWeb.Models.EF.Enums.OrderStatus.Delivering:
                                        statusText = "Đang giao";
                                        break;
                                    case MotorcycleWeb.Models.EF.Enums.OrderStatus.Delivered:
                                        statusText = "Giao thành công";
                                        break;
                                    default:
                                        statusText = "Chưa xác định";
                                        break;
                                }
                            }
                            @statusText
                        </p>
                    </div>
                </div>

            </div>
            <div class="row">
                <div class="col-12">
                    <h2>Danh sách sản phẩm</h2>
                </div>
                <div class="col-12">
                    @Html.Action("Partial_Product","Order",new {id = Model.Id})
                </div>
            </div>
        </div>
        <!-- /.card-body -->
        <div class="card-footer">
            Footer
        </div>
        <!-- /.card-footer-->
    </div>
    <!-- /.card -->

</section>
<!-- /.content -->
<!-- /.content-wrapper -->
