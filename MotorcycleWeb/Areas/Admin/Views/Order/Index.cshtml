@model PagedList.IPagedList<MotorcycleWeb.Models.EF.Order>
@using PagedList;
@using PagedList.Mvc;
@using MotorcycleWeb.Models.EF;  @* import enum OrderStatus *@

@{
    ViewBag.Title = "Danh sách đơn hàng";
}

@section naviheader
{
    <ul class="navbar-nav">
        <li class="nav-item">
            <a class="nav-link" data-widget="pushmenu" href="#" role="button"><i class="fas fa-bars"></i></a>
        </li>
        <li class="nav-item d-none d-sm-inline-block">
            <a href="/admin/home" class="nav-link">Home</a>
        </li>
        <li class="nav-item d-none d-sm-inline-block">
            <a href="/admin/order" class="nav-link">Danh sách đơn hàng</a>
        </li>
    </ul>
}

<section class="content">
    <div class="card">
        <div class="card-header">
            <h3 class="card-title">Danh sách đơn hàng</h3>
        </div>
        <div class="card-body">
            <table class="table table-bordered text-center">
                <thead class="bg-secondary text-white">
                    <tr>
                        <th>#</th>
                        <th>Đơn hàng</th>
                        <th>Tên khách hàng</th>
                        <th>Phone</th>
                        <th>Tiền</th>
                        <th>Thanh toán</th> <!-- giữ TypePayment -->
                        <th>Trạng thái</th> <!-- thêm OrderStatus -->
                        <th>Ngày tạo</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        int i = ((ViewBag.Page - 1) * ViewBag.PageSize) + 1;
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>@i</td>
                                <td>@item.Code</td>
                                <td>@item.CustomerName</td>
                                <td>@item.Phone</td>
                                <td>@item.TotalAmount.ToString("#,##0") VND</td>
                                <td>@(item.TypePayment==1 ? "Chờ thanh toán" : "Đã thanh toán")</td> <!-- giữ nguyên -->
                                <td>
                                    @{
                                        string statusText;
                                        switch (item.Status)
                                        {
                                            case MotorcycleWeb.Models.EF.Enums.OrderStatus.Confirmed:
                                                statusText = "Chờ xác nhận";
                                                break;
                                            case MotorcycleWeb.Models.EF.Enums.OrderStatus.Delivering:
                                                statusText = "Đang giao";
                                                break;
                                            case MotorcycleWeb.Models.EF.Enums.OrderStatus.Delivered:
                                                statusText = "Giao thành công";
                                                break;
                                            default:
                                                statusText = "Chưa xác định";
                                                break;
                                        }
                                    }
                                    @statusText
                                </td>

                                <td>@item.CreateDate.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>
                                    <a href="/admin/order/view/@item.Id" class="btn btn-sm btn-success">Xem</a>
                                    <a href="#" class="btn btn-sm btn-primary btnCapnhat" data-id="@item.Id">Cập nhật</a>
                                </td>
                            </tr>
                            i++;
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="9" class="text-center">Không có đơn hàng nào</td>
                        </tr>
                    }
                </tbody>
            </table>

            <div class="row mt-3">
                <div class="col-6"></div>
                <div class="col-6 text-right">
                    @Html.PagedListPager(Model, page => Url.Action("Index", new { page }))
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Modal cập nhật trạng thái OrderStatus -->
<div class="modal fade" id="modal-default">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h4 class="modal-title">Cập nhật trạng thái</h4>
                <button type="button" class="close" data-dismiss="modal">&times;</button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="txtOrderId" value="0" />
                <div class="form-group">
                    <label>Trạng thái</label>
                    <select class="form-control" id="ddTrangthai">
                        <option value="1">Chờ xác nhận</option>
                        <option value="2">Đang giao</option>
                        <option value="3">Giao thành công</option>
                    </select>
                </div>
            </div>
            <div class="modal-footer justify-content-between">
                <button type="button" class="btn btn-default" data-dismiss="modal">Đóng</button>
                <button type="button" class="btn btn-primary btnLuu">Lưu</button>
            </div>
        </div>
    </div>
</div>

@section scripts{
    <script>
        $(document).ready(function () {
            // Mở modal
            $('body').on('click', '.btnCapnhat', function () {
                var id = $(this).data("id");
                $('#txtOrderId').val(id);
                $('#modal-default').modal('show');
            });

            // Lưu trạng thái OrderStatus
            $('body').on('click', '.btnLuu', function () {
                var id = $('#txtOrderId').val();
                var tt = $('#ddTrangthai').val();
                $.ajax({
                    url: '/admin/order/UpdateTT',
                    type: 'POST',
                    data: { id: id, trangthai: tt },
                    success: function (rs) {
                        if (rs.Success) {
                            location.reload();
                        } else {
                            alert("Cập nhật thất bại!");
                        }
                    },
                    error: function () {
                        alert("Có lỗi xảy ra!");
                    }
                });
            });
        });
    </script>
}
