@model IEnumerable<MotorcycleWeb.Models.EF.Order>
@{
    ViewBag.Title = "Đơn hàng của tôi";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container" style="margin-top:160px; margin-bottom:100px">
    <main aria-labelledby="title" class="col-lg-8 offset-lg-2 col-md-10 offset-md-1">
        <div class="card shadow-lg border-0 rounded-3">
            <div class="card-body p-4">
                <h2 id="title" class="text-center mb-4">@ViewBag.Title</h2>

                @if (!Model.Any())
                {
                    <p class="text-center text-muted">Bạn chưa có đơn hàng nào.</p>
                    <div class="text-center mt-3">
                        @Html.ActionLink("← Back to Home", "Index", "Home", null, new { @class = "text-decoration-none text-secondary" })
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-bordered text-center align-middle">
                            <thead class="bg-secondary text-white">
                                <tr>
                                    <th>#</th>
                                    <th>Mã đơn hàng</th>
                                    <th>Tổng tiền</th>
                                    <th>Ngày đặt</th>
                                    <th>Thanh toán</th>
                                    <th>Trạng thái</th>
                                    <th>Thao tác</th>
                                </tr>
                            </thead>
                            <tbody>
                                @{
                                    int i = 1;
                                    foreach (var item in Model)
                                    {
                                                                <tr>
                                                                    <td>@i</td>
                                                                    <td>@item.Code</td>
                                                                    <td>@item.TotalAmount.ToString("#,##0") VND</td>
                                                                    <td>@item.CreateDate.ToString("dd/MM/yyyy")</td>
                                                                    <td>@(item.TypePayment == 1 ? "Thanh toán khi nhận hàng" : "Thanh toán thẻ ngân hàng")</td>
                                                                    <td>
                                                                        @{
                                                                            string statusText;
                                                                            switch (item.Status)
                                                                            {
                                                                                case MotorcycleWeb.Models.EF.Enums.OrderStatus.Confirmed:
                                                                                    statusText = "Chờ xác nhận";
                                                                                    break;
                                                                                case MotorcycleWeb.Models.EF.Enums.OrderStatus.Delivering:
                                                                                    statusText = "Đang giao";
                                                                                    break;
                                                                                case MotorcycleWeb.Models.EF.Enums.OrderStatus.Delivered:
                                                                                    statusText = "Giao thành công";
                                                                                    break;
                                                                                default:
                                                                                    statusText = "Chưa xác định";
                                                                                    break;
                                                                            }
                                                                        }
                                                                        @statusText
                                                                    </td>

                                                                    <td>
                                                                        <a href="@Url.Action("Details", "OrderHistory", new { id = item.Id })"
                                                                           class="btn btn-sm btn-outline-primary">Xem chi tiết</a>
                                                                    </td>

                                                                </tr>
                                        i++;
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </main>
</div>
